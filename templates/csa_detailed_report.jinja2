    <div class="brb-divider"></div>
    <div class="brb-body">
        <div class="brb-headline">{{_brb_headline}}</div>
    </div>
    <div class="brb-track-wrap">
        <div class="brb-track-label">LOW ←――――――――――――→ CRITICAL</div>
        <div class="brb-track" style="position:relative;">
            <div class="brb-fill" style="width:100%"></div>
            <div class="brb-marker" style="left:{{_brb_pct}}%; background:{% if posture_score < 5 %}#DA291C{% elif posture_score < 7 %}#FF9900{% else %}#FFB800{% endif %};"></div>
        </div>
    </div>
</div>

<!-- Confirmed Clean callout — only shown when at least one category is clear -->
{% if _clean.val > 0 %}
<div class="confirmed-clean">
    <div class="cc-label">&#10003;&nbsp; Assessment confirmed {{_clean.val}} of 5 finding categories are clear</div>
    <div class="cc-items">
        {% if _sc == 0 %}<span class="cc-item">&#10003; No Exposed Secrets</span>{% endif %}
        {% if total_compliance_critical == 0 %}<span class="cc-item">&#10003; Compliance Posture Clean</span>{% endif %}
        {% if total_vuln_critical == 0 %}<span class="cc-item">&#10003; No Critical CVEs</span>{% endif %}
        {% if total_admin.val == 0 %}<span class="cc-item">&#10003; Identity Access Controlled</span>{% endif %}
        {% if critical_alert_count == 0 %}<span class="cc-item">&#10003; No Critical Alerts</span>{% endif %}
    </div>
</div>
{% endif %}

<!-- KPI Grid -->
<div class="exec-kpi-grid">
    {% if _sc > 0 %}
    <div class="exec-kpi-card">
        <div class="ekpi-stripe ekpi-stripe-red"></div>
        <div class="ekpi-label">Exposed Secrets</div>
        <div class="ekpi-num ekpi-red">{{_sc}}</div>
    </div>
    {% endif %}
    <div class="exec-kpi-card">
        <div class="ekpi-stripe {% if total_compliance_critical > 5 %}ekpi-stripe-red{% elif total_compliance_critical > 0 %}ekpi-stripe-orange{% else %}ekpi-stripe-green{% endif %}"></div>
        <div class="ekpi-label">Compliance Gaps</div>
        <div class="ekpi-num {% if total_compliance_critical > 5 %}ekpi-red{% elif total_compliance_critical > 0 %}ekpi-orange{% else %}ekpi-green{% endif %}">{{total_compliance_critical}}</div>
    </div>
    <div class="exec-kpi-card">
        <div class="ekpi-stripe {% if total_vuln_critical > 5 %}ekpi-stripe-red{% elif total_vuln_critical > 0 %}ekpi-stripe-orange{% else %}ekpi-stripe-green{% endif %}"></div>
        <div class="ekpi-label">Critical CVEs</div>
        <div class="ekpi-num {% if total_vuln_critical > 5 %}ekpi-red{% elif total_vuln_critical > 0 %}ekpi-orange{% else %}ekpi-green{% endif %}">{{total_vuln_critical}}</div>
    </div>
    <div class="exec-kpi-card">
        <div class="ekpi-stripe {% if total_admin.val > 10 %}ekpi-stripe-red{% elif total_admin.val > 0 %}ekpi-stripe-amber{% else %}ekpi-stripe-green{% endif %}"></div>
        <div class="ekpi-label">Admin Accounts</div>
        <div class="ekpi-num {% if total_admin.val > 10 %}ekpi-red{% elif total_admin.val > 0 %}ekpi-amber{% else %}ekpi-green{% endif %}">{{total_admin.val}}</div>
    </div>
    <div class="exec-kpi-card">
        <div class="ekpi-stripe {% if critical_alert_count > 3 %}ekpi-stripe-red{% elif critical_alert_count > 0 %}ekpi-stripe-orange{% else %}ekpi-stripe-green{% endif %}"></div>
        <div class="ekpi-label">Critical Alerts</div>
        <div class="ekpi-num {% if critical_alert_count > 3 %}ekpi-red{% elif critical_alert_count > 0 %}ekpi-orange{% else %}ekpi-green{% endif %}">{{critical_alert_count}}</div>
    </div>
</div>

<!-- Attack Chain -->
<div class="attack-chain">
    <div class="ac-label">ATTACK PATH — HOW FINDINGS CHAIN TO A BREACH</div>
    <div class="ac-steps">
        <div class="ac-step {% if _sc > 0 or total_compliance_critical > 0 %}ac-active{% endif %}">
            <div class="ac-icon">&#128273;</div>
            <div class="ac-name">Initial Access</div>
        </div>
        <div class="ac-arrow">&#8594;</div>
        <div class="ac-step {% if total_vuln_critical > 0 %}ac-active{% endif %}">
            <div class="ac-icon">&#128030;</div>
            <div class="ac-name">Code Execution</div>
        </div>
        <div class="ac-arrow">&#8594;</div>
        <div class="ac-step {% if total_identity_high.val > 0 or total_admin.val > 0 %}ac-active{% endif %}">
            <div class="ac-icon">&#128081;</div>
            <div class="ac-name">Privilege Escalation</div>
        </div>
        <div class="ac-arrow">&#8594;</div>
        <div class="ac-step {% if critical_alert_count > 0 %}ac-active{% endif %}">
            <div class="ac-icon">&#128683;</div>
            <div class="ac-name">Lateral Movement</div>
        </div>
        <div class="ac-arrow">&#8594;</div>
        <div class="ac-step ac-active">
            <div class="ac-icon">&#9888;</div>
            <div class="ac-name">Data Breach</div>
        </div>
    </div>
</div>

<!-- Priority Actions -->
<div class="pab-wrapper">
    <div class="pab-header">&#9679; PRIORITY ACTIONS</div>
    <div class="pab-grid">
        <div class="pab-card">
            <div class="pab-time pab-time-now">&#9888; 24 HOURS</div>
            <ul class="pab-list">
                {% if _sc > 0 %}<li>Rotate {{_sc}} exposed secret(s)</li>{% endif %}
                {% if critical_alert_count > 0 %}<li>Triage {{critical_alert_count}} critical alert(s)</li>{% endif %}
                <li>Preserve cloud activity logs</li>
                {% if _sc == 0 and critical_alert_count == 0 %}<li>Confirm no active compromise</li>{% endif %}
            </ul>
        </div>
        <div class="pab-card">
            <div class="pab-time pab-time-week">&#9432; 7 DAYS</div>
            <ul class="pab-list">
                {% if total_compliance_critical > 0 %}<li>Fix {{total_compliance_critical}} compliance gap(s) — IAM first</li>{% endif %}
                {% if total_vuln_critical > 0 %}<li>Patch {{total_vuln_critical}} critical CVE(s)</li>{% endif %}
                <li>Verify change controls are active</li>
                {% if total_compliance_critical == 0 and total_vuln_critical == 0 %}<li>&#10003; No urgent patches required</li>{% endif %}
            </ul>
        </div>
        <div class="pab-card">
            <div class="pab-time pab-time-month">&#9200; 30 DAYS</div>
            <ul class="pab-list">
                {% if total_admin.val > 0 %}<li>Right-size {{total_admin.val}} admin account(s)</li>{% endif %}
                {% if total_identity_high.val > 0 %}<li>Remove {{total_identity_high.val}} over-privileged identit(ies)</li>{% endif %}
                <li>Enable continuous posture monitoring</li>
                <li>Schedule follow-up assessment</li>
            </ul>
        </div>
    </div>
</div>

</section>

{# ═══════════════════════════════════════════════════════
   SECTION 1 — SECRETS
   ═══════════════════════════════════════════════════════ #}
<section id="secrets" class="pagebreak">
{% if not pdf %}<a class="section-back" href="#">&#8592; Back to Overview</a>{% endif %}
<div class="section-hero">
    <div class="sh-ghost-num">01</div>
    <div class="sh-body">
        <div class="sh-eyebrow">Finding Category 01 of 05</div>
        <div class="sh-title">Exposed Secrets</div>
        <div class="sh-impact">Live credentials in world-readable locations bypass all authentication controls — zero additional exploitation required. The #1 fastest path to account compromise.</div>
        <div class="sh-meta">
            {% if _sc > 0 %}<span class="sh-meta-item sh-meta-danger">&#9888; {{_sc}} Risky Secret(s) Found</span><span class="sh-meta-item sh-meta-danger">Time to Exploit: IMMEDIATE</span>
            {% else %}<span class="sh-meta-item sh-meta-clear">&#10003; No Risky Secrets Detected</span>{% endif %}
        </div>
    </div>
    <div class="sh-count-block {% if _sc == 0 %}clean{% endif %}">
        <div class="sh-count-num">{{_sc}}</div>
        <div class="sh-count-unit">EXPOSED</div>
    </div>
</div>
{% if secrets_data and secrets_data.secrets_count > 0 %}
{{ secrets_data.secrets_html | safe }}
{% else %}
<p class="text-muted">No secrets were detected during this assessment period.</p>
{% endif %}

<div class="section-summary">
    <div class="ss-title">&#9650; Risk Summary — Secrets Posture</div>
    {% set _legacy = (secrets_data.legacy_rsa_count if (secrets_data and secrets_data.legacy_rsa_count is defined) else 0) %}
    {% if _sc > 0 %}
    <p><strong style="color:#DA291C;">{{_sc}} exposed secret(s)</strong> were found in world-accessible or insufficiently protected locations (chmod &gt; 600). Each represents a directly usable credential — an attacker with read access bypasses all authentication and authorization controls entirely. The average attacker dwell time after credential theft is <strong style="color:white;">194 days</strong> before detection. Immediate rotation is non-negotiable.</p>
    {% if _legacy > 0 %}
    <p style="margin-top:0.6rem;"><strong style="color:#F5A623;">&#9888; Key Algorithm Advisory:</strong> {{_legacy}} key(s) use the legacy <code>ssh-rsa</code> algorithm. Migrate to <code>ssh-ed25519</code> — run <code>ssh-keygen -t ed25519</code> to generate a replacement, then rotate and revoke the legacy keys.</p>
    {% endif %}
    {% elif secrets_data and secrets_data.secrets_count > 0 %}
    <p><strong style="color:#1E7A3E;">&#10003; No risk exposure.</strong> All {{secrets_data.secrets_count}} detected secret(s) reside in chmod-600 protected locations (owner read-only). These files are accessible only by the owning process or root — they do not constitute an active risk finding. Continue enforcing strict file permissions and rotate keys on a scheduled basis as part of standard security hygiene.</p>
    {% if _legacy > 0 %}
    <p style="margin-top:0.6rem;"><strong style="color:#F5A623;">&#9888; Key Algorithm Advisory:</strong> {{_legacy}} key(s) use the legacy <code>ssh-rsa</code> algorithm. Even though the files are properly protected, migrate to <code>ssh-ed25519</code> — run <code>ssh-keygen -t ed25519</code> to generate a replacement, then rotate and revoke the legacy keys. RSA is susceptible to timing attacks regardless of file permissions.</p>
    {% endif %}
    {% else %}
    <p>No secrets were detected during this assessment period. Maintain continuous secret scanning as part of the CI/CD pipeline and enforce pre-commit hooks to prevent hardcoded credentials from being introduced in future deployments.</p>
    {% endif %}
</div>
</section>

{# ═══════════════════════════════════════════════════════
   SECTION 2 — TOP CRITICAL NON-COMPLIANCE FINDINGS
   ═══════════════════════════════════════════════════════ #}
{% if aws_compliance_data or azure_compliance_data or gcp_compliance_data %}
<section id="compliance" class="pagebreak">
{% if not pdf %}<a class="section-back" href="#">&#8592; Back to Overview</a>{% endif %}
<div class="section-hero">
    <div class="sh-ghost-num">02</div>
    <div class="sh-body">
        <div class="sh-eyebrow">Finding Category 02 of 05</div>
        <div class="sh-title">Critical Non-Compliance</div>
        <div class="sh-impact">Control failures in IAM, networking, and encryption expand the attack surface across all cloud environments — exploitable without specialized attacker tooling.</div>
        <div class="sh-meta">
            {% if total_compliance_critical > 10 %}<span class="sh-meta-item sh-meta-danger">CRITICAL POSTURE</span>
            {% elif total_compliance_critical > 0 %}<span class="sh-meta-item sh-meta-warn">ELEVATED RISK</span>
            {% else %}<span class="sh-meta-item sh-meta-clear">COMPLIANT</span>{% endif %}
            <span class="sh-meta-item sh-meta-info">CIS Benchmark</span>
            {% if aws_compliance_data %}<span class="sh-meta-item sh-meta-info">AWS</span>{% endif %}
            {% if azure_compliance_data %}<span class="sh-meta-item sh-meta-info">Azure</span>{% endif %}
            {% if gcp_compliance_data %}<span class="sh-meta-item sh-meta-info">GCP</span>{% endif %}
        </div>
    </div>
    <div class="sh-count-block {% if total_compliance_critical == 0 %}clean{% endif %}">
        <div class="sh-count-num">{{total_compliance_critical}}</div>
        <div class="sh-count-unit">CRITICAL</div>
    </div>
</div>

{% set ns = namespace(count=0) %}
{% set provider_list = [
    ('AWS',   aws_compliance_data,   'aws'),
    ('Azure', azure_compliance_data, 'azure'),
    ('GCP',   gcp_compliance_data,   'gcp')
] %}

{# Determine account column per provider #}
{% macro acct_col(provider) %}{% if provider == 'AWS' %}Account ID{% elif provider == 'Azure' %}Subscription ID{% else %}Project ID{% endif %}{% endmacro %}

<table class="exec-table">
    <thead>
        <tr>
            <th class="narrow">#</th>
            <th style="width:55px">Severity</th>
            <th style="width:200px">Finding</th>
            <th style="width:120px">Cloud Scope</th>
            <th style="width:90px">Service Area</th>
            <th style="width:180px">Contextual Risk</th>
            <th style="width:180px">Business Impact</th>
            <th style="width:180px">Recommended Fix</th>
            <th style="width:70px">Priority</th>
        </tr>
    </thead>
    <tbody>
    {% for provider, provider_data, badge_class in provider_list %}
      {% if provider_data and provider_data.critical_details is defined and not provider_data.critical_details.empty %}
        {% set acol = acct_col(provider) %}
        {% for idx, row in provider_data.critical_details.iterrows() %}
          {% if ns.count < 10 %}
          {% set ns.count = ns.count + 1 %}
          <tr>
            <td class="narrow">{{ ns.count }}</td>
            <td><span class="badge badge-critical">Critical</span></td>
            <td class="wide">
                <strong>{{ row['Control'] | truncate(90, True, '…') }}</strong>
            </td>
            <td class="med">
                <span class="badge badge-{{ badge_class }}">{{ provider }}</span><br>
                <small class="text-muted">{{ row[acol] | truncate(24, True, '…') }}</small>
            </td>
            <td class="med">{{ row['Category'] }}</td>
            <td class="wide">{{ compliance_context(row['Category']) }}</td>
            <td class="wide">{{ compliance_impact(row['Category']) }}</td>
            <td class="wide">{{ compliance_fix(row['Category']) }}</td>
            <td><span class="badge badge-critical">Immediate</span></td>
          </tr>
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endfor %}
    {% if ns.count == 0 %}
    <tr>
        <td colspan="9" style="text-align:center; color: var(--color-text-muted); padding: 1.5rem;">
            No critical compliance findings detected — or compliance data was not retrieved for this assessment.
        </td>
    </tr>
    {% endif %}
    </tbody>
</table>

<div class="page-break-before"></div>
<div class="section-summary">
    <div class="ss-title">&#9650; Risk Summary — Why Immediate Action Matters</div>
    {% if total_compliance_critical > 0 %}
    <p><strong style="color:#DA291C;">{{total_compliance_critical}} critical compliance finding(s)</strong> were identified across cloud environments. These are not theoretical risks — CIS-critical controls represent the subset of misconfigurations most frequently exploited in pre-breach cloud environments. Unresolved critical findings leave foundational security controls — access management, encryption, network exposure, and audit logging — in a failed state. Each open finding must be treated as an active attack vector until the underlying control is remediated and verified by a rescan.</p>
    {% else %}
    <p>No critical compliance findings were detected. Continue monitoring for configuration drift — cloud environments change continuously and previously clean controls can regress following infrastructure updates, new account provisioning, or IaC deployments.</p>
    {% endif %}
</div>

</section>
{% endif %}

{# ═══════════════════════════════════════════════════════
   SECTION 3 — TOP VULNERABILITIES (RISK SCORE ≥ 9)
   ═══════════════════════════════════════════════════════ #}
{% if host_vulns_data or container_vulns_data %}
<section id="vulnerabilities" class="pagebreak">
{% if not pdf %}<a class="section-back" href="#">&#8592; Back to Overview</a>{% endif %}
<div class="section-hero">
    <div class="sh-ghost-num">03</div>
    <div class="sh-body">
        <div class="sh-eyebrow">Finding Category 03 of 05</div>
        <div class="sh-title">Critical Vulnerabilities — Risk Score ≥ 9</div>
        <div class="sh-impact">Unpatched workloads with publicly known exploit code. Remote code execution pathways confirmed. Each vulnerable host is a foothold into your production environment.</div>
        <div class="sh-meta">
            {% if total_vuln_critical > 5 %}<span class="sh-meta-item sh-meta-danger">CRITICAL EXPOSURE</span>
            {% elif total_vuln_critical > 0 %}<span class="sh-meta-item sh-meta-warn">ACTIVE CVEs</span>
            {% else %}<span class="sh-meta-item sh-meta-clear">NO CRITICAL CVEs</span>{% endif %}
            <span class="sh-meta-item sh-meta-info">FortiCNAPP CWPP</span>
        </div>
    </div>
    <div class="sh-count-block {% if total_vuln_critical == 0 %}clean{% endif %}">
        <div class="sh-count-num">{{total_vuln_critical}}</div>
        <div class="sh-count-unit">WORKLOADS</div>
    </div>
</div>
<p>
    FortiCNAPP filters all assessed CVEs to surface only those with a Risk Score of 9.0 or higher — a composite score that accounts for exploitability, blast radius (number of affected hosts/images), and presence of public exploit code. The following represent the most dangerous unpatched conditions in the environment.
</p>

{% set vuln_ns = namespace(count=0) %}

<table class="exec-table">
    <thead>
        <tr>
            <th class="narrow">#</th>
            <th style="width:55px">Severity</th>
            <th style="width:140px">Vulnerability (CVE)</th>
            <th style="width:60px">Risk Score</th>
            <th style="width:140px">Affected Resource</th>
            <th style="width:130px">Package / Version</th>
            <th style="width:200px">Attacker Outcome if Exploited</th>
            <th style="width:130px">Recommended Fix</th>
            <th style="width:65px">Priority</th>
        </tr>
    </thead>
    <tbody>
    {% if host_vulns_data and host_vulns_data.top_risk_vulns is defined and not host_vulns_data.top_risk_vulns.empty %}
      {% for idx, row in host_vulns_data.top_risk_vulns.iterrows() %}
        {% if vuln_ns.count < 10 %}
        {% set vuln_ns.count = vuln_ns.count + 1 %}
        <tr>
            <td class="narrow">{{ vuln_ns.count }}</td>
            <td>
                {% if row['Severity'] == 'Critical' %}<span class="badge badge-critical">Critical</span>
                {% elif row['Severity'] == 'High' %}<span class="badge badge-high">High</span>
                {% else %}<span class="badge badge-medium">{{ row['Severity'] }}</span>{% endif %}
            </td>
            <td><strong>{{ row['CVE'] }}</strong><br><small class="text-muted">Host</small></td>
            <td style="text-align:center;">
                <span class="risk-chip {% if row['Risk Score'] < 9.5 %}high{% endif %}">{{ row['Risk Score'] }}</span>
            </td>
            <td class="med">{{ row['Hostname'] | truncate(40, True, '…') }}</td>
            <td class="med">
                {{ row['Package'] }}<br>
                <small class="text-muted">v{{ row['Installed Version'] | truncate(20) }}</small>
            </td>
            <td class="wide">{{ vuln_attacker_outcome(row['CVE'], row['Severity']) }}</td>
            <td class="med">
                {% if 'Fixed Version' in row and row['Fixed Version'] and row['Fixed Version'] != 'None' %}
                    Update <strong>{{ row['Package'] }}</strong> to v{{ row['Fixed Version'] | truncate(20) }}
                {% else %}
                    Apply vendor patch; consult CVE advisory for workarounds.
                {% endif %}
            </td>
            <td><span class="badge badge-critical">Immediate</span></td>
        </tr>
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if container_vulns_data and container_vulns_data.top_risk_vulns is defined and not container_vulns_data.top_risk_vulns.empty %}
      {% for idx, row in container_vulns_data.top_risk_vulns.iterrows() %}
        {% if vuln_ns.count < 10 %}
        {% set vuln_ns.count = vuln_ns.count + 1 %}
        <tr>
            <td class="narrow">{{ vuln_ns.count }}</td>
            <td>
                {% if row['Severity'] == 'Critical' %}<span class="badge badge-critical">Critical</span>
                {% elif row['Severity'] == 'High' %}<span class="badge badge-high">High</span>
                {% else %}<span class="badge badge-medium">{{ row['Severity'] }}</span>{% endif %}
            </td>
            <td><strong>{{ row['CVE'] }}</strong><br><small class="text-muted">Container</small></td>
            <td style="text-align:center;">
                <span class="risk-chip {% if row['Risk Score'] < 9.5 %}high{% endif %}">{{ row['Risk Score'] }}</span>
            </td>
            <td class="med">{{ row['Repository'] | truncate(40, True, '…') }}</td>
            <td class="med">
                {{ row['Package'] }}<br>
                <small class="text-muted">v{{ row['Installed Version'] | truncate(20) }}</small>
            </td>
            <td class="wide">{{ vuln_attacker_outcome(row['CVE'], row['Severity']) }}</td>
            <td class="med">
                {% if 'Fixed Version' in row and row['Fixed Version'] and row['Fixed Version'] != 'None' %}
                    Rebuild image with <strong>{{ row['Package'] }}</strong> v{{ row['Fixed Version'] | truncate(20) }}
                {% else %}
                    Update base image; consult CVE advisory for workarounds.
                {% endif %}
            </td>
            <td><span class="badge badge-critical">Immediate</span></td>
        </tr>
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if vuln_ns.count == 0 %}
    <tr>
        <td colspan="9" style="text-align:center; color: var(--color-text-muted); padding: 1.5rem;">
            No vulnerabilities with Risk Score ≥ 9 were detected, or vulnerability data was not retrieved.
        </td>
    </tr>
    {% endif %}
    </tbody>
</table>

<div class="info-box note">
    <div class="info-box-icon">ℹ</div>
    <div class="info-box-content">
        <strong>FortiCNAPP Risk Score Explained</strong>
        <p>The Risk Score (1–10) is a composite metric calculated by FortiCNAPP that weighs CVSS severity, number of affected hosts/images, package blast radius, and the presence of public exploit code. A score of 9.0+ places a vulnerability in the top tier requiring immediate attention regardless of CVSS alone.</p>
    </div>
</div>

{% if host_vulns_data and host_vulns_data.host_patch_priority %}
{% set _hp = host_vulns_data.host_patch_priority %}
{% set _hp_max = (_hp | map(attribute='count') | list | max) %}
{% set _hp_max = _hp_max if _hp_max > 0 else 1 %}
<div style="display:flex; justify-content:center; margin: 1.5rem 0;">
<div class="apple-chart" style="width:100%; max-width:720px;">
    <div class="apple-chart-title">Host Patch Priority — High-Risk CVE Count per Host</div>
    {% for item in _hp %}
    <div class="chart-row">
        <div class="chart-row-label">{{ item.hostname | truncate(38, True, '…') }}</div>
        <div class="chart-track">
            <div class="chart-bar" style="width:{{ ((item.count / _hp_max) * 100) | int }}%"></div>
        </div>
        <div class="chart-row-value">{{ item.count }}</div>
    </div>
    {% endfor %}
</div>
</div>
{% endif %}

{% if container_vulns_data and container_vulns_data.fixable_vulns is defined and not container_vulns_data.fixable_vulns.empty %}
<div class="page-break-before"></div>
<h3>Container Vulnerabilities — Fixable Critical CVEs</h3>
{{ container_vulns_data.fixable_vulns.to_html(index=False) | safe }}
{% endif %}

<div class="section-summary">
    <div class="ss-title">&#9650; Risk Summary — Why Immediate Action Matters</div>
    {% if total_vuln_critical > 0 %}
    <p><strong style="color:#DA291C;">{{total_vuln_critical}} host(s) and/or container(s)</strong> are running with unpatched CVEs at FortiCNAPP Risk Score 9 or higher. This composite score accounts for CVSS severity, the number of affected assets, blast radius, and the presence of public exploit code — meaning real-world attack tooling is available and actively used against these vulnerabilities. The average time to exploit a disclosed CVE is <strong style="color:white;">12 days</strong>. For every day patching is deferred in this tier, the probability of a successful, in-the-wild exploitation event increases measurably.</p>
    {% else %}
    <p>No vulnerabilities at Risk Score ≥ 9 were detected in the assessed environment. Maintain the patch management cadence and continue scanning as new CVEs are disclosed — the threat landscape changes daily and previously clean workloads can become vulnerable following new CVE publications.</p>
    {% endif %}
</div>

</section>
{% endif %}

{# ═══════════════════════════════════════════════════════
   SECTION 4 — IDENTITY & ENTITLEMENTS
   ═══════════════════════════════════════════════════════ #}
{% if ciem_data %}
<section id="identity" class="pagebreak">
{% if not pdf %}<a class="section-back" href="#">&#8592; Back to Overview</a>{% endif %}
<div class="section-hero">
    <div class="sh-ghost-num">04</div>
    <div class="sh-body">
        <div class="sh-eyebrow">Finding Category 04 of 05</div>
        <div class="sh-title">Identity, Privileged Access &amp; Entitlements</div>
        <div class="sh-impact">Overprivileged identities amplify every other finding. A single compromised admin credential grants environment-wide access — rendering all other controls irrelevant.</div>
        <div class="sh-meta">
