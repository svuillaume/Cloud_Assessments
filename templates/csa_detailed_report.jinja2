        </div>

        {% set _tf = _sc + total_compliance_critical + total_vuln_critical + total_admin.val + critical_alert_count %}
        {% if _tf > 0 %}
          {% set _circ = 565.5 %}
          {% set _gap = 4.0 %}
          {% set _a_s  = [(_sc / _tf * _circ) - _gap, 0] | max %}
          {% set _a_co = [(total_compliance_critical / _tf * _circ) - _gap, 0] | max %}
          {% set _a_v  = [(total_vuln_critical / _tf * _circ) - _gap, 0] | max %}
          {% set _a_ad = [(total_admin.val / _tf * _circ) - _gap, 0] | max %}
          {% set _a_al = [(critical_alert_count / _tf * _circ) - _gap, 0] | max %}
          {% set _ns = namespace(o = -(_circ / 4.0)) %}
          {% set _o_s  = _ns.o %}{% set _ns.o = _ns.o - (_sc / _tf * _circ) %}
          {% set _o_co = _ns.o %}{% set _ns.o = _ns.o - (total_compliance_critical / _tf * _circ) %}
          {% set _o_v  = _ns.o %}{% set _ns.o = _ns.o - (total_vuln_critical / _tf * _circ) %}
          {% set _o_ad = _ns.o %}{% set _ns.o = _ns.o - (total_admin.val / _tf * _circ) %}
          {% set _o_al = _ns.o %}
        {% endif %}
        <svg class="cover-donut-svg" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg">
            <circle cx="110" cy="110" r="90" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="22"/>
