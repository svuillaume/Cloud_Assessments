                <div class="cover-card-sub">{% if total_compliance_critical > 0 %}Critical violations{% else %}&#10003; Compliant{% endif %}</div>
            </a>
            <a class="cover-card {% if total_vuln_critical > 0 %}cc-amber{% else %}cc-green{% endif %}" href="#vulnerabilities">
