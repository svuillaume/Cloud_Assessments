{# ═══════════════════════════════════════════════════════
   SECTION 0 — EXECUTIVE SUMMARY
   ═══════════════════════════════════════════════════════ #}
<section id="exec-summary" class="pagebreak">

{# Determine breach risk level from posture score #}
{% if posture_score < 3 %}
  {% set _brb_level = 'CRITICAL' %}{% set _brb_class = 'brb-level-critical' %}
  {% set _brb_headline = 'Priority remediation plan included — addressing these findings significantly reduces risk.' %}
  {% set _brb_sub = 'Several high-severity findings were identified. This report includes a clear 30-day action roadmap to close these gaps and strengthen your cloud security posture.' %}
  {% set _brb_pct = 92 %}
{% elif posture_score < 5 %}
  {% set _brb_level = 'HIGH' %}{% set _brb_class = 'brb-level-critical' %}
  {% set _brb_headline = 'Targeted improvements identified — a focused remediation plan is included.' %}
  {% set _brb_sub = 'Key gaps were found in cloud posture. The findings in this report, with the accompanying roadmap, provide a clear path to materially improving security this quarter.' %}
  {% set _brb_pct = 72 %}
{% elif posture_score < 7 %}
  {% set _brb_level = 'ELEVATED' %}{% set _brb_class = 'brb-level-elevated' %}
  {% set _brb_headline = 'Good foundation with clear improvement areas — remediation roadmap inside.' %}
  {% set _brb_sub = 'The assessment confirmed a solid baseline. Addressing the identified gaps will move the organization to a strong, defensible cloud security posture.' %}
  {% set _brb_pct = 48 %}
{% else %}
  {% set _brb_level = 'MODERATE' %}{% set _brb_class = 'brb-level-moderate' %}
  {% set _brb_headline = 'Strong security posture — a few targeted improvements will complete the picture.' %}
  {% set _brb_sub = 'Overall cloud security posture is within acceptable risk tolerance. Remaining findings are manageable and can be addressed through standard remediation cycles.' %}
  {% set _brb_pct = 26 %}
{% endif %}

{# Count clean categories for the positive callout #}
{% set _clean = namespace(val=0) %}
{% if _sc == 0 %}{% set _clean.val = _clean.val + 1 %}{% endif %}
{% if total_compliance_critical == 0 %}{% set _clean.val = _clean.val + 1 %}{% endif %}
{% if total_vuln_critical == 0 %}{% set _clean.val = _clean.val + 1 %}{% endif %}
{% if total_admin.val == 0 %}{% set _clean.val = _clean.val + 1 %}{% endif %}
{% if critical_alert_count == 0 %}{% set _clean.val = _clean.val + 1 %}{% endif %}

<!-- Breach Risk Indicator -->
<div class="breach-risk-bar">
    <div class="brb-level-block">
        <div class="brb-level-label">BREACH RISK</div>
        <div class="brb-level-value {{_brb_class}}">{{_brb_level}}</div>
