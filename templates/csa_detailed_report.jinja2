                <div class="cover-card-label">Critical CVEs</div>
                <div class="cover-card-sub">{% if total_vuln_critical > 0 %}Risk score &ge; 9{% else %}&#10003; No critical CVEs{% endif %}</div>
            </a>
            <a class="cover-card {% if total_admin.val > 0 %}cc-purple{% else %}cc-green{% endif %}" href="#identity">
