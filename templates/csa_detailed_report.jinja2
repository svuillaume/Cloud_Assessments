            {% if _sc > 0 %}
            <circle cx="110" cy="110" r="90" fill="none" stroke="#DA291C" stroke-width="22"
                    stroke-dasharray="{{ _a_s }} {{ _circ }}" stroke-dashoffset="{{ _o_s }}" stroke-linecap="butt"/>
            {% endif %}
            {% if total_compliance_critical > 0 %}
            <circle cx="110" cy="110" r="90" fill="none" stroke="#CC6B1A" stroke-width="22"
