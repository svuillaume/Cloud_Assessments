# ── FortiCNAPP API credentials ────────────────────────────────────────────────
# Download from: FortiCNAPP console → Settings → Configuration → API Keys → Create New → Download
LW_ACCOUNT=your-tenant.lacework.net
LW_KEY_ID=FORTINET_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LW_SECRET=_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server port ───────────────────────────────────────────────────────────────
# Use 80 for production (required for Let's Encrypt HTTP-01 challenge)
PORT=80

# ── Let's Encrypt (HTTPS) ─────────────────────────────────────────────────────
# REQUIRED for HTTPS. Set DOMAIN + LE_EMAIL to enable automatic TLS via certbot.
# Both must be set together — LE_EMAIL is mandatory when DOMAIN is set.
# Port 80 must be publicly reachable BEFORE starting the container (HTTP-01 challenge).
# Remove or comment out these lines to run in plain HTTP mode.
DOMAIN=rapidassessment.yourdomain.com
LE_EMAIL=you@example.com

# ── Self-signed certificate (HTTPS without Let's Encrypt) ─────────────────────
# Set SELF_SIGNED=true to skip certbot and generate a local self-signed cert.
# Useful when DNS is not yet propagated or the server is on a private network.
# Browser will show an "untrusted cert" warning — click Advanced → Proceed.
# SELF_SIGNED=true

# ── Optional: supply your own certificate (skips certbot and self-signed) ─────
# TLS_CERT=/certs/fullchain.pem
# TLS_KEY=/certs/privkey.pem
